    setTimeout(function(){
        if(i > 0){
            document.getElementById(steps[i-1]).className = 'step done';
        }
        var curr = document.getElementById(id);
        curr.className = 'step active';
        document.getElementById('bar').style.width = progArr[i] + '%';
    }, times[i]);
});

setTimeout(function(){
    document.getElementById('s4').className = 'step done';
