function getRisk($score){
    if($score >= 70) return array('HIGH',   '#ff4444', '🔴');
    if($score >= 40) return array('MEDIUM', '#ff9800', '🟡');
    return                  array('LOW',    '#00c853', '🟢');
}

$plagiarism = isset($data['plagiarism']) ? $data['plagiarism'] : 0;
$aiScore    = isset($data['ai_score'])   ? $data['ai_score']   : 0;
$selfScore  = isset($data['self'])       ? $data['self']       : 0;
$overall    = round(($plagiarism * 0.6) + ($aiScore * 0.4), 1);

list($pRisk, $pColor, $pIcon) = getRisk($plagiarism);
list($aRisk, $aColor, $aIcon) = getRisk($aiScore);
list($oRisk, $oColor, $oIcon) = getRisk($overall);
